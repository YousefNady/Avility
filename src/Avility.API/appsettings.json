{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=avility.db"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_USER_SECRET_MIN_32_CHARS",
    "Issuer": "Avility",
    "Audience": "AvilityClients",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "FileStorage": {
    "LocalRootPath": "App_Data/resumes"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
